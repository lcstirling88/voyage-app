// Voyage — travel itinerary app
// Postgres (Neon) for production; local dev uses the same DATABASE_URL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// Auth.js models (https://authjs.dev/getting-started/adapters/prisma)
// ============================================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  // ISO 3166-1 numeric code of the user's country of residence. Paints
  // that country in burgundy with a gold edge on the Atlas map, and
  // separates it from travel destinations in the country list + stats.
  homeCountryIso String?

  accounts         Account[]
  sessions         Session[]
  memberships      Membership[]
  invitesSent      Invitation[]      @relation("InvitesSent")
  visitedCountries VisitedCountry[]
}

// User-added "I've been there" records for the Atlas — for trips taken
// before they joined Voyage, or short visits they didn't plan in the app.
// One row per (user, country); editing happens by upserting on isoNumeric.
model VisitedCountry {
  id           String   @id @default(cuid())
  userId       String
  isoNumeric   String   // ISO 3166-1 numeric, matches the destinations registry
  daysApprox   Int?     // optional rough days, counts toward Atlas tier rank
  yearVisited  Int?     // optional rough year, just for display on the card
  note         String?  // free-text memory, optional
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, isoNumeric])
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================================
// Voyage domain models
// ============================================================================

model Trip {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  tagline       String?
  destination   String
  themeKey      String   @default("default")
  startDate     DateTime
  endDate       DateTime
  homeCurrency  String   @default("AUD")
  localCurrency String?  // ISO code of the destination's currency (e.g. NZD)
  timezone      String   @default("UTC") // IANA, e.g. "Pacific/Auckland"
  inboxToken    String   @unique
  travelerNames String?
  departureCity String?

  // Party composition for AI-aware suggestions and packing
  adultCount    Int      @default(1)
  childCount    Int      @default(0)
  childrenAges  String?  // comma-separated ages, e.g. "8, 11"

  // AI-generated local info for the destination (tipping, power, phrases, etc.)
  localInfoJson String?  // JSON blob — see lib/local-info.ts for shape

  // Colour palette for accommodation bars in itinerary: 'pastel' | 'jewel' | 'mono'
  colorPalette  String   @default("pastel")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cities         City[]
  segments       TripSegment[]
  bookings       Booking[]
  documents      Document[]
  payments       Payment[]
  checklistItems ChecklistItem[]
  emails         IncomingEmail[]
  memberships    Membership[]
  invitations    Invitation[]
}

// A leg of a multi-country trip: one country with its own date range. Trips
// with no segments are treated as a single implicit leg derived from
// Trip.destination, so existing single-country trips keep working unchanged.
// Powers per-leg adaptation (clock, currency, weather) and per-country
// aggregation (visa, local info, packing).
model TripSegment {
  id           String   @id @default(cuid())
  tripId       String
  country      String   // friendly label, e.g. "Japan"
  isoNumeric   String?  // ISO 3166-1 numeric, for profile/flag lookup
  startDate    DateTime
  endDate      DateTime
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

model Membership {
  id        String   @id @default(cuid())
  tripId    String
  userId    String
  role      String   @default("editor") // 'owner' | 'editor'
  createdAt DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
  @@index([userId])
  @@index([tripId])
}

model Invitation {
  id        String   @id @default(cuid())
  tripId    String
  email     String
  invitedBy String
  role      String   @default("editor")
  token     String   @unique
  acceptedAt DateTime?
  createdAt DateTime @default(now())

  trip   Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  sender User @relation("InvitesSent", fields: [invitedBy], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([email])
}

model City {
  id           String   @id @default(cuid())
  tripId       String
  name         String
  country      String
  arriveOn     DateTime
  leaveOn      DateTime
  lat          Float?
  lng          Float?
  displayOrder Int      @default(0)

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  @@index([tripId])
}

model Booking {
  id                 String    @id @default(cuid())
  tripId             String
  type               String
  title              String
  vendor             String?
  startAt            DateTime
  endAt              DateTime?
  location           String?
  address            String?
  confirmationCode   String?
  notes              String?
  cost               Float?
  currency           String?
  paid               Boolean   @default(false)
  paidAt             DateTime?
  paymentMethod      String?
  metadata           String?

  // Cancellation policy extracted from confirmation emails
  cancelByAt         DateTime?
  cancellationPolicy String?

  sourceEmailId      String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  trip        Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  sourceEmail IncomingEmail? @relation(fields: [sourceEmailId], references: [id], onDelete: SetNull)

  @@index([tripId])
  @@index([startAt])
  @@index([cancelByAt])
}

model Document {
  id            String   @id @default(cuid())
  tripId        String
  category      String
  title         String
  filename      String?
  mimeType      String?
  storagePath   String?
  notes         String?
  sourceEmailId String?
  createdAt     DateTime @default(now())

  trip        Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  sourceEmail IncomingEmail? @relation(fields: [sourceEmailId], references: [id], onDelete: SetNull)

  @@index([tripId])
}

model Payment {
  id            String    @id @default(cuid())
  tripId        String
  bookingId     String?
  description   String
  amount        Float
  currency      String
  dueDate       DateTime
  autoPay       Boolean   @default(false)
  paymentMethod String?
  paid          Boolean   @default(false)
  paidAt        DateTime?
  createdAt     DateTime  @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([dueDate])
}

model ChecklistItem {
  id        String    @id @default(cuid())
  tripId    String
  section   String
  category  String?
  text      String
  done      Boolean   @default(false)
  doneAt    DateTime?
  position  Int       @default(0)
  createdAt DateTime  @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  @@index([tripId])
}

model IncomingEmail {
  id            String   @id @default(cuid())
  tripId        String?
  fromAddress   String
  toAddress     String
  subject       String
  textBody      String?
  htmlBody      String?
  receivedAt    DateTime @default(now())
  processed     Boolean  @default(false)
  parsedSummary String?
  parsedJson    String?
  errorMsg      String?

  trip        Trip?             @relation(fields: [tripId], references: [id], onDelete: SetNull)
  attachments EmailAttachment[]
  bookings    Booking[]
  documents   Document[]

  @@index([tripId])
  @@index([receivedAt])
}

model EmailAttachment {
  id          String @id @default(cuid())
  emailId     String
  filename    String
  mimeType    String
  storagePath String
  size        Int

  email IncomingEmail @relation(fields: [emailId], references: [id], onDelete: Cascade)
  @@index([emailId])
}
